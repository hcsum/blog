---
import type { BlogEntry } from "@/lib/blog";
import { formatDate, getPostMeta } from "@/lib/blog";

interface Props {
  entry: BlogEntry;
}

const { entry } = Astro.props;
const meta = getPostMeta(entry);
---

<article class="glass-panel group rounded-[1.75rem] p-6 transition duration-300 hover:-translate-y-1 hover:border-[color:var(--accent)]">
  <div class="mb-4 flex flex-wrap items-center gap-3 text-sm text-[color:var(--muted)]">
    <span class="rounded-full border border-[color:var(--line)] px-3 py-1">{meta.section}</span>
    {meta.publishedAt && <time datetime={meta.publishedAt.toISOString()}>{formatDate(meta.publishedAt)}</time>}
    <span>{meta.readingTime} min read</span>
  </div>
  <h2 class="mb-3 text-2xl font-semibold tracking-tight text-[color:var(--foreground)]">
    <a class="transition group-hover:text-[color:var(--accent)]" href={meta.permalink}>
      {meta.title}
    </a>
  </h2>
  <p class="mb-5 text-base leading-7 text-[color:var(--muted)]">{meta.description}</p>
  <div class="flex flex-wrap gap-2 text-xs uppercase tracking-[0.18em] text-[color:var(--accent)]">
    {meta.tags.slice(0, 3).map((tag) => <span>{tag}</span>)}
  </div>
</article>
