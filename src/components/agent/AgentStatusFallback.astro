<section
  aria-busy="true"
  aria-label="Loading agent status"
  class="agent-console-shell border-b border-[color:var(--line)]"
>
  <div class="mx-auto max-w-7xl px-5 py-16 md:py-20">
    <div class="grid gap-6 lg:grid-cols-[1.08fr_0.92fr] lg:items-start">
      <div class="space-y-6">
        <section class="agent-panel agent-hero-panel rounded-[2rem] p-6 md:p-8">
          <div class="agent-skeleton-chip h-7 w-36 rounded-full"></div>
          <div class="mt-8 flex justify-center">
            <div class="agent-skeleton-orb"></div>
          </div>
          <div class="mt-8 space-y-4">
            <div class="agent-skeleton-line h-12 w-full max-w-[30rem] rounded-2xl"></div>
            <div class="agent-skeleton-line h-5 w-full max-w-[36rem] rounded-full"></div>
            <div class="agent-skeleton-line h-5 w-[78%] rounded-full"></div>
          </div>
        </section>

        <section class="flex flex-col gap-3 sm:flex-row sm:flex-wrap">
          <article class="agent-panel agent-stat-card min-w-0 flex-1 rounded-[1rem] px-5 py-4">
            <div class="agent-skeleton-line h-3 w-24 rounded-full"></div>
            <div class="agent-skeleton-line mt-4 h-9 w-32 rounded-2xl"></div>
          </article>
          <article class="agent-panel agent-stat-card min-w-0 flex-1 rounded-[1rem] px-5 py-4">
            <div class="agent-skeleton-line h-3 w-20 rounded-full"></div>
            <div class="agent-skeleton-line mt-4 h-9 w-28 rounded-2xl"></div>
          </article>
          <article class="agent-panel agent-stat-card min-w-0 flex-1 rounded-[1rem] px-5 py-4">
            <div class="agent-skeleton-line h-3 w-28 rounded-full"></div>
            <div class="agent-skeleton-line mt-4 h-9 w-20 rounded-2xl"></div>
          </article>
        </section>
      </div>

      <section class="agent-panel agent-stream-panel rounded-[2rem] p-6">
        <div class="mb-6 flex items-end justify-between gap-4">
          <div class="space-y-3">
            <div class="agent-skeleton-line h-3 w-28 rounded-full"></div>
            <div class="agent-skeleton-line h-7 w-40 rounded-2xl"></div>
          </div>
          <div class="agent-skeleton-chip h-7 w-16 rounded-full"></div>
        </div>

        <div class="space-y-4">
          <article class="agent-skeleton-card rounded-[0.625rem] border border-[color:var(--line)] p-5">
            <div class="flex items-center gap-3">
              <div class="agent-skeleton-chip h-7 w-20 rounded-full"></div>
              <div class="agent-skeleton-line ml-auto h-3 w-20 rounded-full"></div>
            </div>
            <div class="agent-skeleton-line mt-4 h-6 w-[65%] rounded-2xl"></div>
            <div class="agent-skeleton-line mt-3 h-4 w-full rounded-full"></div>
            <div class="agent-skeleton-line mt-2 h-4 w-[82%] rounded-full"></div>
          </article>

          <article class="agent-skeleton-card rounded-[0.625rem] border border-[color:var(--line)] p-5">
            <div class="flex items-center gap-3">
              <div class="agent-skeleton-chip h-7 w-24 rounded-full"></div>
              <div class="agent-skeleton-line ml-auto h-3 w-20 rounded-full"></div>
            </div>
            <div class="agent-skeleton-line mt-4 h-6 w-[58%] rounded-2xl"></div>
            <div class="agent-skeleton-line mt-3 h-4 w-full rounded-full"></div>
            <div class="agent-skeleton-line mt-2 h-4 w-[74%] rounded-full"></div>
          </article>

          <article class="agent-skeleton-card rounded-[0.625rem] border border-[color:var(--line)] p-5">
            <div class="flex items-center gap-3">
              <div class="agent-skeleton-chip h-7 w-16 rounded-full"></div>
              <div class="agent-skeleton-line ml-auto h-3 w-20 rounded-full"></div>
            </div>
            <div class="agent-skeleton-line mt-4 h-6 w-[61%] rounded-2xl"></div>
            <div class="agent-skeleton-line mt-3 h-4 w-full rounded-full"></div>
            <div class="agent-skeleton-line mt-2 h-4 w-[69%] rounded-full"></div>
          </article>
        </div>
      </section>
    </div>
  </div>
</section>
