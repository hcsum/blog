---
import "@/styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Haochen Xu | Writing, experiments, and web craft",
  description = "A content-driven personal site for essays, engineering notes, and frontend experiments.",
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#0f766e" />
    <link rel="canonical" href={canonical} />
    <script is:inline>
      const savedTheme = localStorage.getItem("theme");
      const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
      if (savedTheme === "dark" || (!savedTheme && prefersDark)) {
        document.documentElement.classList.add("dark");
      }
    </script>
  </head>
  <body>
    <div class="site-shell">
      <header class="sticky top-0 z-40 border-b border-[color:var(--line)] bg-[color:var(--surface-strong)]/90 backdrop-blur-xl">
        <div class="mx-auto flex max-w-6xl items-center justify-between px-5 py-4">
          <a class="text-sm font-semibold tracking-[0.24em] text-[color:var(--accent)] uppercase" href="/">
            Haochen Xu
          </a>
          <nav class="flex items-center gap-4 text-sm font-medium text-[color:var(--muted)]">
            <a class="transition hover:text-[color:var(--foreground)]" href="/posts/">Posts</a>
            <a class="transition hover:text-[color:var(--foreground)]" href="/threejs/">Three.js</a>
            <button
              id="theme-toggle"
              class="rounded-full border border-[color:var(--line)] px-3 py-1.5 text-xs uppercase tracking-[0.2em] text-[color:var(--foreground)] transition hover:border-[color:var(--accent)] hover:text-[color:var(--accent)]"
              type="button"
            >
              Theme
            </button>
          </nav>
        </div>
      </header>
      <main>
        <slot />
      </main>
      <footer class="border-t border-[color:var(--line)] py-10">
        <div class="mx-auto flex max-w-6xl flex-col gap-3 px-5 text-sm text-[color:var(--muted)] md:flex-row md:items-center md:justify-between">
          <p>Built with Astro, React, Markdown, and an unhealthy amount of curiosity.</p>
          <p>sumtsui@gmail.com</p>
        </div>
      </footer>
    </div>
    <script is:inline>
      const button = document.querySelector("#theme-toggle");
      button?.addEventListener("click", () => {
        document.documentElement.classList.toggle("dark");
        localStorage.setItem(
          "theme",
          document.documentElement.classList.contains("dark") ? "dark" : "light",
        );
      });
    </script>
  </body>
</html>
