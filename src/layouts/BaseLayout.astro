---
import "@/styles/global.css";
import AgentHeaderIndicator from "@/components/agent/AgentHeaderIndicator";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Haochen Xu | Writing, experiments, and web craft",
  description = "Personal site of Haochen Xu, with writing about software, engineering notes, and frontend experiments.",
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html class="dark" lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#0f766e" />
    <link rel="canonical" href={canonical} />
  </head>
  <body>
    <div class="site-shell">
      <header class="sticky top-0 z-40 border-b border-[color:var(--line)] bg-[color:var(--surface-strong)]/90 backdrop-blur-xl">
        <div class="mx-auto max-w-6xl px-4 py-3 sm:flex sm:items-center sm:justify-between sm:px-5 sm:py-4">
          <div class="flex items-center justify-between gap-3">
            <a
              class="brand-glitch text-[0.68rem] font-semibold tracking-[0.2em] uppercase sm:text-sm sm:tracking-[0.24em]"
              data-text="Haochen Xu"
              href="/"
            >
              Haochen Xu
            </a>
            <div class="sm:hidden">
              <AgentHeaderIndicator client:only="react" compact />
            </div>
          </div>
          <nav class="mt-3 flex items-center gap-5 text-sm font-medium text-[color:var(--muted)] sm:mt-0 sm:gap-9">
            <a
              class="rounded-full border border-[color:var(--line)] px-3 py-1.5 transition hover:text-[color:var(--foreground)] sm:border-transparent sm:px-0 sm:py-0"
              href="/posts/"
            >
              Posts
            </a>
            <a
              class="rounded-full border border-[color:var(--line)] px-3 py-1.5 transition hover:text-[color:var(--foreground)] sm:border-transparent sm:px-0 sm:py-0"
              href="/lab/"
            >
              Lab
            </a>
            <div class="hidden sm:block">
              <AgentHeaderIndicator client:only="react" />
            </div>
          </nav>
        </div>
      </header>
      <main>
        <slot />
      </main>
      <footer class="border-t border-[color:var(--line)] py-10">
        <div class="mx-auto flex max-w-6xl flex-col gap-3 px-5 text-sm text-[color:var(--muted)] md:flex-row md:items-center md:justify-between">
          <p>Writing, experiments, and ongoing work.</p>
          <p>hi@hcxu.cc</p>
        </div>
      </footer>
    </div>
  </body>
</html>
