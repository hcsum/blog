---
import { getCollection, render } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import TableOfContents from "@/components/TableOfContents.astro";
import { formatDate, getPostMeta } from "@/lib/blog";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const meta = getPostMeta(post);
const { Content, headings } = await render(post);
const isBilingual = post.data.bilingual ?? false;
const defaultLang = post.data.defaultLang ?? "en";
const titleZh = post.data.titleZh ?? meta.title;
const titleEn = post.data.titleEn ?? meta.title;
const descriptionZh = post.data.descriptionZh ?? meta.description;
const descriptionEn = post.data.descriptionEn ?? meta.description;
const pageTitle = defaultLang === "zh" ? titleZh : titleEn;
const pageDescription = defaultLang === "zh" ? descriptionZh : descriptionEn;
const ogImageAlt = post.data.ogImageAlt ?? pageTitle;
const tocHeadings = headings.filter((heading) => heading.depth >= 2 && heading.depth <= 3);
const h1Indexes = headings.reduce<number[]>((indexes, heading, index) => {
  if (heading.depth === 1) {
    indexes.push(index);
  }
  return indexes;
}, []);
const bilingualTocHeadings =
  isBilingual && h1Indexes.length >= 2
    ? {
        zh: headings
          .slice(h1Indexes[0] + 1, h1Indexes[1])
          .filter((heading) => heading.depth >= 2 && heading.depth <= 3),
        en: headings.slice(h1Indexes[1] + 1).filter((heading) => heading.depth >= 2 && heading.depth <= 3),
      }
    : undefined;
---

<BaseLayout
  title={`${pageTitle} | Haochen Xu`}
  description={pageDescription}
  socialTitle={pageTitle}
  type="article"
  image={post.data.ogImage ? { src: post.data.ogImage, alt: ogImageAlt } : undefined}
  article={{
    publishedTime: meta.publishedAt,
    section: meta.section,
    tags: meta.tags,
  }}
>
  <article class="mx-auto max-w-6xl px-5 py-14">
    <a class="mb-8 inline-flex items-center gap-2 text-sm font-semibold text-[color:var(--accent)]" href="/posts/">
      <span aria-hidden="true">←</span>
      Back to posts
    </a>

    <header class="mb-12 max-w-3xl">
      <div class="mb-5 flex flex-wrap items-center gap-3 text-sm text-[color:var(--muted)]">
        <span class="rounded-full border border-[color:var(--line)] px-3 py-1">{meta.section}</span>
        {meta.publishedAt && <time datetime={meta.publishedAt.toISOString()}>{formatDate(meta.publishedAt)}</time>}
        <span>{meta.readingTime} min read</span>
      </div>
      <h1
        class="text-4xl font-semibold leading-tight tracking-tight md:text-6xl"
        data-page-title-zh={isBilingual ? titleZh : undefined}
        data-page-title-en={isBilingual ? titleEn : undefined}
      >
        {pageTitle}
      </h1>
      <p
        class="mt-5 text-lg leading-8 text-[color:var(--muted)]"
        data-page-description-zh={isBilingual ? descriptionZh : undefined}
        data-page-description-en={isBilingual ? descriptionEn : undefined}
      >
        {pageDescription}
      </p>
    </header>

    <div class="grid grid-cols-1 gap-10 lg:grid-cols-[minmax(0,1fr)_17rem]">
      <div class="glass-panel rounded-[2rem] p-6 md:p-10">
        {isBilingual && (
          <div class="mb-8 flex flex-wrap items-center justify-between gap-4 rounded-[1.5rem] border border-[color:var(--line)] bg-[color:var(--surface)] px-4 py-3">
            <p class="text-sm text-[color:var(--muted)]">Language / 语言</p>
            <div class="inline-flex items-center gap-1 rounded-full border border-[color:var(--line)] p-1" data-language-toggle>
              <button
                class="rounded-full px-3 py-1.5 text-sm font-medium text-[color:var(--muted)] transition"
                data-lang-choice="zh"
                type="button"
              >
                中文
              </button>
              <button
                class="rounded-full px-3 py-1.5 text-sm font-medium text-[color:var(--muted)] transition"
                data-lang-choice="en"
                type="button"
              >
                EN
              </button>
            </div>
          </div>
        )}
        <div class="prose prose-lg" data-bilingual-root={isBilingual ? "true" : undefined} data-post-lang={defaultLang}>
          <Content />
        </div>
      </div>
      <TableOfContents headings={tocHeadings} headingsByLang={bilingualTocHeadings} currentLang={defaultLang} />
    </div>
  </article>
</BaseLayout>

{isBilingual && (
  <>
    <style>
      [data-bilingual-root][data-post-lang="zh"] [data-lang="en"],
      [data-bilingual-root][data-post-lang="en"] [data-lang="zh"] {
        display: none;
      }

      [data-language-toggle] [data-lang-choice][data-active="true"] {
        background: var(--accent);
        color: var(--surface-strong);
      }
    </style>

    <script is:inline define:vars={{ defaultLang, postId: post.id }}>
      const root = document.querySelector("[data-bilingual-root]");
      const buttons = Array.from(document.querySelectorAll("[data-lang-choice]"));
      const storageKey = `post-language:${postId}`;
      const titleNode = document.querySelector("[data-page-title-zh]");
      const descriptionNode = document.querySelector("[data-page-description-zh]");

      if (root && buttons.length > 0) {
        const applyLanguage = (lang) => {
          root.setAttribute("data-post-lang", lang);

          if (titleNode) {
            const nextTitle =
              lang === "zh" ? titleNode.getAttribute("data-page-title-zh") : titleNode.getAttribute("data-page-title-en");
            if (nextTitle) {
              titleNode.textContent = nextTitle;
              document.title = `${nextTitle} | Haochen Xu`;
            }
          }

          if (descriptionNode) {
            const nextDescription =
              lang === "zh"
                ? descriptionNode.getAttribute("data-page-description-zh")
                : descriptionNode.getAttribute("data-page-description-en");
            if (nextDescription) {
              descriptionNode.textContent = nextDescription;
            }
          }

          document.querySelectorAll("[data-toc-lang]").forEach((list) => {
            list.hidden = list.getAttribute("data-toc-lang") !== lang;
          });

          buttons.forEach((button) => {
            const active = button.getAttribute("data-lang-choice") === lang;
            button.setAttribute("data-active", active ? "true" : "false");
            button.setAttribute("aria-pressed", active ? "true" : "false");
          });
          window.localStorage.setItem(storageKey, lang);
        };

        const savedLang = window.localStorage.getItem(storageKey);
        applyLanguage(savedLang === "zh" || savedLang === "en" ? savedLang : defaultLang);

        buttons.forEach((button) => {
          button.addEventListener("click", () => {
            const lang = button.getAttribute("data-lang-choice");
            if (lang === "zh" || lang === "en") {
              applyLanguage(lang);
            }
          });
        });
      }
    </script>
  </>
)}
