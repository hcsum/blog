---
import { getCollection, render } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import TableOfContents from "@/components/TableOfContents.astro";
import { formatDate, getPostMeta } from "@/lib/blog";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const meta = getPostMeta(post);
const { Content, headings } = await render(post);
const isBilingual = post.data.bilingual ?? false;
const defaultLang = post.data.defaultLang ?? "en";
---

<BaseLayout title={`${meta.title} | Haochen Xu`} description={meta.description}>
  <article class="mx-auto max-w-6xl px-5 py-14">
    <a class="mb-8 inline-flex items-center gap-2 text-sm font-semibold text-[color:var(--accent)]" href="/posts/">
      <span aria-hidden="true">←</span>
      Back to posts
    </a>

    <header class="mb-12 max-w-3xl">
      <div class="mb-5 flex flex-wrap items-center gap-3 text-sm text-[color:var(--muted)]">
        <span class="rounded-full border border-[color:var(--line)] px-3 py-1">{meta.section}</span>
        {meta.publishedAt && <time datetime={meta.publishedAt.toISOString()}>{formatDate(meta.publishedAt)}</time>}
        <span>{meta.readingTime} min read</span>
      </div>
      <h1 class="text-4xl font-semibold leading-tight tracking-tight md:text-6xl">{meta.title}</h1>
      <p class="mt-5 text-lg leading-8 text-[color:var(--muted)]">{meta.description}</p>
    </header>

    <div class="grid grid-cols-1 gap-10 lg:grid-cols-[minmax(0,1fr)_17rem]">
      <div class="glass-panel rounded-[2rem] p-6 md:p-10">
        {isBilingual && (
          <div class="mb-8 flex flex-wrap items-center justify-between gap-4 rounded-[1.5rem] border border-[color:var(--line)] bg-[color:var(--surface)] px-4 py-3">
            <p class="text-sm text-[color:var(--muted)]">Language / 语言</p>
            <div class="inline-flex items-center gap-1 rounded-full border border-[color:var(--line)] p-1" data-language-toggle>
              <button
                class="rounded-full px-3 py-1.5 text-sm font-medium text-[color:var(--muted)] transition"
                data-lang-choice="zh"
                type="button"
              >
                中文
              </button>
              <button
                class="rounded-full px-3 py-1.5 text-sm font-medium text-[color:var(--muted)] transition"
                data-lang-choice="en"
                type="button"
              >
                EN
              </button>
            </div>
          </div>
        )}
        <div class="prose prose-lg" data-bilingual-root={isBilingual ? "true" : undefined} data-post-lang={defaultLang}>
          <Content />
        </div>
      </div>
      <TableOfContents headings={headings.filter((heading) => heading.depth >= 2 && heading.depth <= 3)} />
    </div>
  </article>
</BaseLayout>

{isBilingual && (
  <>
    <style>
      [data-bilingual-root][data-post-lang="zh"] [data-lang="en"],
      [data-bilingual-root][data-post-lang="en"] [data-lang="zh"] {
        display: none;
      }

      [data-language-toggle] [data-lang-choice][data-active="true"] {
        background: var(--accent);
        color: var(--surface-strong);
      }
    </style>

    <script is:inline define:vars={{ defaultLang, postId: post.id }}>
      const root = document.querySelector("[data-bilingual-root]");
      const buttons = Array.from(document.querySelectorAll("[data-lang-choice]"));
      const storageKey = `post-language:${postId}`;

      if (root && buttons.length > 0) {
        const applyLanguage = (lang) => {
          root.setAttribute("data-post-lang", lang);
          buttons.forEach((button) => {
            const active = button.getAttribute("data-lang-choice") === lang;
            button.setAttribute("data-active", active ? "true" : "false");
            button.setAttribute("aria-pressed", active ? "true" : "false");
          });
          window.localStorage.setItem(storageKey, lang);
        };

        const savedLang = window.localStorage.getItem(storageKey);
        applyLanguage(savedLang === "zh" || savedLang === "en" ? savedLang : defaultLang);

        buttons.forEach((button) => {
          button.addEventListener("click", () => {
            const lang = button.getAttribute("data-lang-choice");
            if (lang === "zh" || lang === "en") {
              applyLanguage(lang);
            }
          });
        });
      }
    </script>
  </>
)}
